{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Default preset for general use",
  "extends": [
    "config:recommended",
    ":semanticCommits",
    ":semanticCommitScope(deps)",
    ":gitSignOff",
    ":configMigration",
    "helpers:pinGitHubActionDigests",
    "customManagers:githubActionsVersions"
  ],
  "baseBranchPatterns": ["$default"],
  "prCreation": "immediate",
  "rebaseWhen": "behind-base-branch",
  "automergeType": "pr",
  "platformAutomerge": true,
  "prHourlyLimit": 5,
  "packageRules": [
    {
      "description": "Use semantic commit type `ci` for updates in GitHub Actions files",
      "matchFileNames": ["/^\\.github/(?:workflows|actions)/.+\\.ya?ml$/"],
      "additionalBranchPrefix": "ci-",
      "semanticCommitType": "ci"
    }
  ]
}
